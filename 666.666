<!DOCTYPE html>
<html>
  <head>
	<meta charset="utf-8" name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
	<title>WebCat</title>
<style>
         body{background-color:pink;

      }
      h1{
          color:  red;
          text-align:center;
          margin-top:  20px;

     }

        input,button{
                 display:block;
                 margin:  0   auto;
                 font-size:   20px
                 margin-top:10px;
          }
</style>

  </head>
  <body>	
	  <h1>输入你的年龄</h1>
      <h1>我就可以算出你的年龄</h1>
      <input   type="text"/>
      <button>确定</button>
    

       <script>
                let button = document.querySelector("button")
                //按钮点击事件
                button.onclick = function(){
                      //获取输入框的密码
                   let  input = document.querySelector("input")
                   
                   alert(input.value);


         }

       </script>




  </body>
</html>
