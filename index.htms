<!DOCTYPE html>
<html>
  <head>
	<meta charset="utf-8" name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
	<title>WebCat</title>
<style>
         body{background-color:pink;

      }
       h1{
          color:  red;
          text-align:center;
          margin-top:  200px;
          
       }

         

        input,button{
                 display:block;
                 margin:  0   auto;
                 font-size:   20px;
                 margin-top:10px;
          }
</style>
  </head>
  <body>	
	  <h1>请输入密码进入</h1>
      <input   type="text"/>
      <button>确定</button>
    

       <script>
                let button = document.querySelector("button")
                //按钮点击事件
                button.onclick = function(){
                      //获取输入框的密码
                    
                   let  input = document.querySelector("input")
                     //如果输入的密码等于666 则输入正确
                  if(input.value=="666"){
                     document.body. innerHTML    =    "<h1>你成功浪费了你人生中宝贵的1秒</h1>"



                     }else{
                      alert("密码错误,请重新输入");


            }
             
                 

     }
    

       </script>
       

  </body>
</html
